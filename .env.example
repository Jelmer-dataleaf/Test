# ── OpenAI (needed for AI-powered test generation) ────────────────────────────
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Model to use for test generation (default: gpt-4o)
OPENAI_MODEL=gpt-4o

# ── Git options ───────────────────────────────────────────────────────────────
# Override the commit range to inspect (default: HEAD~1 HEAD)
# GIT_COMMIT_RANGE=HEAD~3 HEAD

# ── Playwright options ────────────────────────────────────────────────────────
# Base URL of your application under test — angular dev server default
BASE_URL=http://localhost:4200
